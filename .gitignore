docs/12-Traceability/
docs/13-API/
docs/14-Frontend/
docs/17-Templates/
docs/18-Review/
docs/Proj-Docs-v-6
docs/develop/crm/
docs/develop/build/


# Config
*.keystore
.flattened-pom.xml

# Others
*.swp
*.xml.versionsBackup
yarn.lock
pnpm-lock.yaml
package-lock.json

