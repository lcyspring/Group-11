# IDE
.idea/
*.iml
*.iws
*.ipr
.history/
.vscode/

# Build
target/

build/
!docs/20-CRM-Delivery/build/
!docs/20-CRM-Delivery/build/**
.gradle/
dist/
dist-*
*.class
*.jar
*.war

# Web/build contains Vite configuration source, not generated output.
!Web/build/
!Web/build/**

# Dependencies
node_modules/
.pnpm-store/
unpackage/
backups/

# Environment
.env
.env.local
application-my.yaml

# The management Web build requires this shared Vite configuration. VITE_
# values are shipped to browsers and must not contain server-side secrets.
!Web/.env
!MallFrontend/.env

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Docker
docker-images/*.tar

# Legacy Docker/runtime directories removed from the repository. Keep any
# locally recreated copies out of source control.
/dev/
/docker-compose/
/docker-images/

# Runtime upload data is disposable and recreated by the application.
/uploads/

# Podman offline OCI image archives
podman/images/*.tar
podman/images/*.sha256
podman/config/build-image-archives-local.yaml

# Local source-analysis documents (kept out of product commits)
docs/01-Existing-System-Analysis/
docs/02-Prototype-Analysis/
docs/03-Gap-Analysis/
docs/04-Requirements-Landing-Analysis/
docs/05-Requirements-Analysis/
docs/06-DevSecOps/
docs/07-Organization/
docs/08-Project-Planning/
docs/09-Sprint-Plan/
docs/10-Testing/
docs/12-Database/
docs/12-Traceability/
docs/13-API/
docs/14-Frontend/
docs/17-Templates/
docs/18-Review/
docs/Proj-Docs-v-6

# Local daily reports are working notes and are not part of repository delivery.
docs/20-CRM-Delivery/daily/

# Local stateful runtime configuration may contain deployment credentials.
podman/config/runtime-local.yaml
podman/config/runtime-local-rebuild-server.yaml
podman/config/database-backup-local.yaml
podman/config/runtime-local-rebuild-web.yaml
podman/config/runtime-local-rebuild-mall.yaml
podman/config/bpm-provision-local.yaml
podman/config/bpm-provision-*-local.yaml
podman/config/verify-*-local.yaml


# Config
*.keystore
.flattened-pom.xml

# Others
*.swp
*.xml.versionsBackup
yarn.lock
pnpm-lock.yaml
package-lock.json

# Pin the management Web dependency graph so a fresh clone builds the same
# assets on every machine.
!Web/pnpm-lock.yaml
