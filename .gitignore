# IDE
.idea/
*.iml
*.iws
*.ipr
.history/
.vscode/

# Build
target/

build/
.gradle/
dist/
dist-*
*.class
*.jar
*.war

# Web/build contains Vite configuration source, not generated output.
!Web/build/
!Web/build/**

# Dependencies
node_modules/
.pnpm-store/
unpackage/
# The current Mall H5 release is distributed through Git so deployment
# members do not need HBuilderX. Other unpackage outputs remain ignored.
!MallFrontend/unpackage/
!MallFrontend/unpackage/dist/
!MallFrontend/unpackage/dist/build/
!MallFrontend/unpackage/dist/build/web/
!MallFrontend/unpackage/dist/build/web/**

# Environment
.env
.env.local
application-my.yaml

# The management Web build requires this shared Vite configuration. VITE_
# values are shipped to browsers and must not contain server-side secrets.
!Web/.env
!MallFrontend/.env

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Docker
docker-images/*.tar

# Podman offline OCI image archives
podman/images/*.tar

# Local project-analysis and delivery documents (kept out of product commits)
docs/01-Existing-System-Analysis/
docs/02-Prototype-Analysis/
docs/03-Gap-Analysis/
docs/04-Requirements-Landing-Analysis/
docs/05-Requirements-Analysis/
docs/06-DevSecOps/
docs/07-Organization/
docs/08-Project-Planning/
docs/09-Sprint-Plan/
docs/10-Testing/
