{
  "info": {
    "_postman_id": "mitedtsm-api-collection",
    "name": "MITEDTSM API Collection",
    "description": "密讯ETM系统完整接口测试集合\n技术栈：JDK17 + SpringBoot 3.5.9 + Vue3 + TypeScript\nJava包名：com.meession.etm\n多租户：支持(tenant-id header)\n\n包含10个Folder共30个接口测试用例，覆盖System/CRM/ERP/BPM/Mall/WMS核心模块",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01-认证模块-System-Auth",
      "description": "系统认证模块：登录、登出、Token刷新、验证码、权限信息",
      "item": [
        {
          "name": "获取验证码",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('响应包含captchaId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('captchaId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin-api/system/auth/captcha",
              "host": ["{{baseUrl}}"],
              "path": ["admin-api", "system", "auth", "captcha"]
            }
          }
        },
        {
          "name": "用户登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('响应包含token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('token');",
                  "    pm.environment.set('token', jsonData.data.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "tenant-id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"captchaId\": \"\",\n  \"captchaCode\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin-api/system/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["admin-api", "system", "auth", "login"]
            }
          }
        },
        {
          "name": "获取当前用户权限信息",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('状态码为200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "tenant-id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin-api/system/auth/get-permission-info",
              "host": ["{{baseUrl}}"],
              "path": ["admin-api", "system", "auth", "get-permission-info"]
            }
          }
        }
      ]
    },
