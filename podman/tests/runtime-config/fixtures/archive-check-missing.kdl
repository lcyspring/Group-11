schema_version 1

operation {
  archive_mode "check"
}

network {
  use_host_proxy #false
  http_proxy "none"
  https_proxy "none"
  all_proxy "none"
  no_proxy "127.0.0.1,localhost"
}

image {
  archive_dir "archives-that-do-not-exist"
  runtime_base "example.invalid/runtime:1"
  mysql_base "example.invalid/mysql:1"
  redis_base "example.invalid/redis:1"
  rabbitmq_base "example.invalid/rabbitmq:1"
  tdengine_base "example.invalid/tdengine:1"
  nginx_base "example.invalid/nginx:1"
}

archive {
  runtime_base "runtime.tar"
  mysql_base "mysql.tar"
  redis_base "redis.tar"
  rabbitmq_base "rabbitmq.tar"
  tdengine_base "tdengine.tar"
  nginx_base "nginx.tar"
}
