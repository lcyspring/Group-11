schema_version 1

endpoint {
  base_url "http://127.0.0.1:8080/admin-api"
  tenant_id 1
}
account {
  username "admin"
  password "CHANGE_ME"
}
approval {
  role_code "crm_marketing_approver"
  role_name "CRM 营销群发审批人"
  role_sort 52
  approver_username "admin"
  permission_codes "bpm:task:query,bpm:task:update,bpm:process-instance:query,crm:marketing-outreach:query,crm:marketing-outreach:review"
}
