schema_version 1

endpoint {
  base_url "http://127.0.0.1:8080/admin-api"
  tenant_id 1
}

account {
  username "CHANGE_ME"
  password "CHANGE_ME"
}

approval {
  role_code "oa_work_request_approver"
  role_name "OA 请示审批人"
  role_sort 63
  approver_username "CHANGE_ME"
  permission_codes "bpm:task:query,bpm:task:update,bpm:process-instance:query,bpm:oa-work-request:query"
}

category {
  code "OA_COLLABORATION"
  name "办公协作"
  sort 60
}

model {
  key "oa_work_request"
  name "OA 请示审批"
  description "OA 请示审批；审批结果回写请示业务状态。"
  form_create_path "/bpm/collaboration/work-request"
  form_view_path "/bpm/oa/work-request/detail.vue"
  approval_node_name "请示审批"
}
