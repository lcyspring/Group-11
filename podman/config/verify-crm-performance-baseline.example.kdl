schema_version 1


endpoint {
  base_url "http://127.0.0.1:8080/admin-api"
  tenant_id 1

}

account {
  username "admin"
  password "CHANGE_ME"

}

workload {
  warmup_requests 3
  requests_per_scenario 100
  concurrency 8
  timeout_seconds 15
  page_size 10
  department_id 103
  interval 1
  start_time "2026-01-01 00:00:00"
  end_time "2026-12-31 23:59:59"

}

thresholds {
  max_error_rate_percent 1.0
  max_p95_ms 800
  max_p99_ms 1500
  min_throughput_rps 5.0

}

containers {
  server "mitedtsm-rootless-server"
  mysql "mitedtsm-rootless-mysql"
  redis "mitedtsm-rootless-redis"

}

mysql {
  user "root"
  password "CHANGE_ME"
  database "mitedtsm_database"

}

evidence {
  output_dir "../../docs/20-CRM-Delivery/evidence/crm-performance-baseline/runs"
}
