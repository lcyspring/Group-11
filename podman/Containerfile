# Build from the repository root, for example:
# podman build --file podman/Containerfile --target server .
#
# This file packages existing application artifacts only. It does not invoke
# Maven, pnpm, HBuilderX, or package database SQL. MySQL uses its official
# image and deploy.sh streams repository manifests during deployment.

ARG RUNTIME_BASE_IMAGE=docker.io/library/eclipse-temurin:17-jdk
ARG NGINX_BASE_IMAGE=docker.io/library/nginx:stable-alpine

FROM ${RUNTIME_BASE_IMAGE} AS runtime-base

ENV TZ=Asia/Shanghai

FROM runtime-base AS init-service
WORKDIR /opt/mitedtsm-init-service
COPY InitService/target/mitedtsm-init-service.jar app.jar
CMD ["java", "-jar", "app.jar"]

FROM runtime-base AS server
WORKDIR /opt/mitedtsm-server
COPY Server/mitedtsm-server/target/mitedtsm-server.jar app.jar
ENV JAVA_OPTS="-Xms512m -Xmx512m -Djava.security.egd=file:/dev/./urandom"
CMD ["sh", "-c", "exec java ${JAVA_OPTS} -jar app.jar --spring.profiles.active=${SPRING_PROFILES_ACTIVE:-local}"]

FROM ${NGINX_BASE_IMAGE} AS web
COPY podman/nginx/web.conf /etc/nginx/conf.d/default.conf
COPY Web/dist-prod/ /usr/share/nginx/html/

FROM ${NGINX_BASE_IMAGE} AS mall
COPY podman/nginx/mall.conf /etc/nginx/conf.d/default.conf
COPY MallFrontend/unpackage/dist/build/web/ /usr/share/nginx/html/
